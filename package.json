{
    "private": true,
    "type": "module",
    "module": "src/main.ts",
    "scripts": {
        "dev": "bun --watch run src/main.ts",
        "start": "bun .",
        "lint": "oxlint --config .oxlintrc.json",
        "lint-fix": "oxlint --config .oxlintrc.json --fix",
        "format": "oxfmt --check",
        "format-fix": "oxfmt",
        "typecheck": "bun run tsc --project tsconfig.strict.json",
        "test": "bun test --concurrent",
        "check-all": "bun run format && bun run lint && bun run typecheck && bun run test"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "discord-api-types": "^0.38.45",
        "express": "^5.2.1",
        "express-rate-limit": "^8.3.2"
    },
    "devDependencies": {
        "@types/bun": "latest",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "oxfmt": "^0.44.0",
        "oxlint": "^1.59.0",
        "oxlint-tsgolint": "^0.20.0"
    },
    "peerDependencies": {
        "typescript": "^6.0.2"
    }
}
